    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\n\nlet rawText = \"\";\nif (inputData.content && inputData.content.parts && inputData.content.parts[0]) {\n    rawText = inputData.content.parts[0].text;\n} else if (inputData.text) {\n    rawText = inputData.text;\n} else if (inputData.output) {\n    rawText = inputData.output;\n}\n\nconst jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\nlet aiData = {};\n\nif (jsonMatch) {\n    try {\n        aiData = JSON.parse(jsonMatch[0]);\n    } catch (e) {\n        return { error: \"Błąd parsowania\", raw: rawText };\n    }\n} else {\n    return { error: \"Nie znaleziono JSONa w tekście\", raw: rawText };\n}\n\nlet webhookData = {};\ntry { webhookData = $('Webhook').first().json; } catch(e) {}\n\nlet link = \"\";\ntry { link = $('Upload file').first().json.webViewLink || \"\"; } catch(e) {}\n\nconst formatField = (list, field, prefix) => {\n    if (!Array.isArray(list)) return \"\";\n    return list.map((item, i) => `${prefix} ${i + 1}: ${item[field] || ''}`).join('\\n');\n};\n\nreturn {\n    zleceniodawca_nip: aiData.zleceniodawca_nip || \"\",\n    zleceniodawca_nazwa: aiData.zleceniodawca_nazwa || \"\",\n    cena_eur: aiData.cena_eur || \"\",\n    data_zal: aiData.data_zal || \"\",\n    data_roz: aiData.data_roz || \"\",\n    zaladunek_kod: formatField(aiData.zaladunki, 'kod', 'ZAL'),\n    zaladunek_miasto: formatField(aiData.zaladunki, 'miasto', 'ZAL'),\n    zaladunek_ulica: formatField(aiData.zaladunki, 'ulica', 'ZAL'),\n    rozladunek_kod: formatField(aiData.rozladunki, 'kod', 'ROZ'),\n    rozladunek_miasto: formatField(aiData.rozladunki, 'miasto', 'ROZ'),\n    rozladunek_ulica: formatField(aiData.rozladunki, 'ulica', 'ROZ'),\n    numer_zlecenia: aiData.numer_zlecenia || \"\",\n    \n    webviewlink: link || webhookData.body?.webviewlink || webhookData.query?.webviewlink || \"\",\n    LEO: webhookData.body?.leo || webhookData.query?.leo || \"\",\n    \"sped/stol\": webhookData.body?.spedytor || webhookData.query?.spedytor || \"AW\",\n    KM: webhookData.body?.km || webhookData.query?.km || \"\"\n};"
      },
